TRUSTMRR_API_KEY=replace-with-your-server-key
DATABASE_PATH=./data/leaderboard.sqlite
TRUSTMRR_BASE_URL=https://trustmrr.com/api/v1

# Preferred with Clash on the server: expose Clash's local HTTP/mixed port
# and let the app only talk to 127.0.0.1. Do NOT store your upstream proxy
# node credentials in this project.
HTTPS_PROXY=http://127.0.0.1:7890

# Optional fallback. If you use it, prefer an HTTP proxy URL from Clash's
# mixed port rather than putting raw upstream node secrets here.
# ALL_PROXY=http://127.0.0.1:7890
